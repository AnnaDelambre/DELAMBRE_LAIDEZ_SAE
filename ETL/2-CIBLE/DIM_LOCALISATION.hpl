    <limit>0</limit>
    <sql>SELECT 
  c.code_departement,
  c.nom_commune AS commune,
  AVG(a.latitude) AS latitude,
  AVG(a.longitude) AS longitude
FROM COMMUNE c
LEFT JOIN ADRESSE a
  ON c.code_commune = a.code_commune
GROUP BY 
  c.code_departement,
  c.nom_commune</sql>
