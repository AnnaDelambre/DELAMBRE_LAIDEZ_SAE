    <connection>MUTATIONS_SOURCE</connection>
    <execute_each_row>N</execute_each_row>
    <limit>0</limit>
    <sql>WITH ncp_clean AS (
    SELECT
        id_parcelle,
        id_mutation,
        id_nature,
        MAX(surface_terrain) AS surface_terrain
    FROM NatureCultureParcelle
    GROUP BY id_parcelle, id_mutation, id_nature
),
tp_clean AS (
    SELECT
        id_parcelle,
        id_mutation,
        code_type_local AS id_type_local
    FROM TypeParcelle
    GROUP BY id_parcelle, id_mutation, code_type_local
)

SELECT
    p.id_parcelle,
    p.id_mutation,

    /* ✅ sécurisation nombre (très important pour ton ORA-01722) */
    CASE 
        WHEN REGEXP_LIKE(m.valeur_fonciere, '^[0-9]+([.,][0-9]+)?$')
        THEN TO_NUMBER(REPLACE(m.valeur_fonciere, ',', '.'))
        ELSE NULL
    END AS valeur_fonciere,

    /* ✅ dimensions avec UNKNOWN */
    NVL(ncp.id_nature, 'UNKNOWN') AS id_nature,
    NVL(ncp.surface_terrain, -1) AS surface_terrain,

    NVL(tp.id_type_local, -1) AS id_type_local,

    NVL(p.surface_reelle_bati, -1) AS surface_reelle_bati,
    NVL(p.nombre_pieces_principales, -1) AS nombre_pieces_principales,
    NVL(p.nombre_lots, -1) AS nombre_lots,

    NVL(m.date_mutation, DATE '0001-01-01') AS id_date,

    NVL(c.CODE_DEPARTEMENT || c.NOM_COMMUNE, 'UNKNOWN') AS id_localisation

FROM Parcelle p

LEFT JOIN Mutation m
    ON p.id_mutation = m.id_mutation

LEFT JOIN ncp_clean ncp
    ON p.id_parcelle = ncp.id_parcelle
    AND p.id_mutation = ncp.id_mutation

LEFT JOIN tp_clean tp
    ON p.id_parcelle = tp.id_parcelle
    AND p.id_mutation = tp.id_mutation

LEFT JOIN Adresse a
    ON p.id_adresse = a.id_adresse

LEFT JOIN Commune c
    ON a.code_commune = c.code_commune</sql>
