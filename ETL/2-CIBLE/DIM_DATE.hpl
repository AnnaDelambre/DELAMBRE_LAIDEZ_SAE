    <limit>0</limit>
    <sql>SELECT DISTINCT
    date_mutation AS id_date,
    EXTRACT(YEAR FROM date_mutation) AS annee,
    TO_NUMBER(TO_CHAR(date_mutation, 'Q')) AS trimestre,
    EXTRACT(MONTH FROM date_mutation) AS mois,
    TO_CHAR(date_mutation, 'MONTH', 'NLS_DATE_LANGUAGE=FRENCH') AS nom_mois,
    EXTRACT(DAY FROM date_mutation) AS jour,
    TO_CHAR(date_mutation, 'DAY', 'NLS_DATE_LANGUAGE=FRENCH') AS nom_jour

FROM Mutation
WHERE date_mutation IS NOT NULL</sql>
